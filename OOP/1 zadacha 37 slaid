class Monster:
    def __init__(self, name, hp, dmg ):
        self.name=name; self.hp=hp; self.dmg=dmg
        
    def show_info(self):
        print(f"Имя монстра {self.name}")
        print(f"Хп монстра {self.hp}")
        print(f"Урон монстра {self.dmg}")
        print(f"-"*15)
        
        
m1 = Monster("Горгулья",120,18)
m1.show_info()
