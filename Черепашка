SUN_RANGE = 16
SUN_WIDTH = 6
SUN_FORWARD = 90
SUN_CIRCLE = 60
SUN_COLOR1 = "orange"
SUN_COLOR2 = "yellow"
def create_sun(x1, y1, x2, y2):
    sun = t.color(SUN_COLOR1)
    t.width(SUN_WIDTH)
    for i in range(SUN_RANGE):
     t.penup()
     t.goto(x1, y1)
     t.pendown()
     t.setheading(i * 22.5)
     t.forward(SUN_FORWARD)
    t.width(1)
    t.penup()
    t.goto(x2,y2)
    t.pendown()
    t.color(SUN_COLOR2)
    t.begin_fill()
    t.circle(SUN_CIRCLE)
    t.end_fill()
    return sun

GRASS_COLOR = "green"
BLADE_COUNT = 10
START_X = -400
START_Y = -340
GRASS_RANGE = 80
GRASS_FORWARD = 10
BLADE_CIRCLE = 70
t.color(GRASS_COLOR)
for i in range(GRASS_RANGE):
    t.penup()
    t.goto(START_X + i * BLADE_COUNT, START_Y)
    t.pendown()
    d = 1 if i % 2 == 0 else -1
    t.setheading(75 + (i % 5) * 10)
    t.width(3 - (i % 2))
    n = BLADE_CIRCLE + (i % 2)
    for j in range(int(n / 10)):
        t.forward(GRASS_FORWARD)
        t.left(5 * d)
    t.width(1)

