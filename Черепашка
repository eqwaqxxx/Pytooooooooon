STEM_COLOR = "darkgreen"
STEM_WIDTH = 4
STEM_SETHEADING = 90
STEM_FORWARD = 150
PETAL_WIDTH = 1
PETAL_RADIUS = 40
CENTER_COLOR = "yellow"
CENTER_RADIUS = 30
CENTER_X = -20
CENTER_Y = -200
def create_petal(PETAL_COLOR,x1,y1, x2, y2, x3, y3):
    t.color(STEM_COLOR)
    t.width(STEM_WIDTH)
    t.penup()
    t.goto(x1,y1)
    t.pendown()
    t.setheading(STEM_SETHEADING)
    t.forward(STEM_FORWARD)
    t.width(PETAL_WIDTH)
    t.color(PETAL_COLOR)
    for i in range(8):
        t.penup()
        t.goto(x2, y2)
        t.pendown()
        t.setheading(i * 45)
        t.begin_fill()
        t.circle(PETAL_RADIUS, 180)
        t.circle(PETAL_RADIUS, 180)
        t.end_fill()
    t.penup()
    t.goto(x3, y3)
    t.pendown()
    t.color(CENTER_COLOR)
    t.begin_fill()
    t.circle(CENTER_RADIUS)
    t.end_fill()
    return create_petal
