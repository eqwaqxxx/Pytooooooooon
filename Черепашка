import turtle
# --- Настройки экрана ---
t = turtle.Turtle()
t.speed(0)
turtle.tracer(0, 0)
t.hideturtle()
screen = turtle.Screen()
screen.bgcolor("lightblue")
screen.setup(width=800, height=700)

# =====================================================
# ПАРА 1 — СОЛНЫШКО
# =====================================================
SUN_RANGE = 16
SUN_WIDTH = 6
SUN_FORWARD = 90
SUN_CIRCLE = 60
SUN_COLOR1 = "orange"
SUN_COLOR2 = "yellow"
def create_sun(x1, y1, x2, y2):
    sun = t.color(SUN_COLOR1)
    t.width(SUN_WIDTH)
    for i in range(SUN_RANGE):
     t.penup()
     t.goto(x1, y1)
     t.pendown()
     t.setheading(i * 22.5)
     t.forward(SUN_FORWARD)
    t.width(1)
    t.penup()
    t.goto(x2,y2)
    t.pendown()
    t.color(SUN_COLOR2)
    t.begin_fill()
    t.circle(SUN_CIRCLE)
    t.end_fill()
    return sun

BLADE_COUNT = 20
GRASS_RANGE = 50
GRASS_FORWARD = 10
BLADE_CIRCLE = 70
def create_grass(x, y, color):
    t.color(color)
    for i in range(GRASS_RANGE):
        t.penup()
        t.goto(x + i * BLADE_COUNT, y)
        t.pendown()
        d = 1 if i % 2 == 0 else -1
        t.setheading(75 + (i % 5) * 10)
        t.width(3 - (i % 2))
        n = BLADE_CIRCLE + (i % 2)
        for j in range(int(n / 10)):
            t.forward(GRASS_FORWARD)
            t.left(5 * d)
        t.width(1)

# =====================================================
# ПАРА 3 — ЦВЕТОК
# =====================================================
STEM_COLOR = "darkgreen"
STEM_WIDTH = 4
STEM_SETHEADING = 90
STEM_FORWARD = 150
PETAL_WIDTH = 1
PETAL_RADIUS = 30
CENTER_COLOR = "yellow"
CENTER_RADIUS = 20
CENTER_X = -20
CENTER_Y = -200
def create_petal(PETAL_COLOR,x1,y1, x2, y2, x3, y3):
    t.color(STEM_COLOR)
    t.width(STEM_WIDTH)
    t.penup()
    t.goto(x1,y1)
    t.pendown()
    t.setheading(STEM_SETHEADING)
    t.forward(STEM_FORWARD)
    t.width(PETAL_WIDTH)
    t.color(PETAL_COLOR)
    for i in range(8):
        t.penup()
        t.goto(x2, y2)
        t.pendown()
        t.setheading(i * 45)
        t.begin_fill()
        t.circle(PETAL_RADIUS, 180)
        t.circle(PETAL_RADIUS, 180)
        t.end_fill()
    t.penup()
    t.goto(x3, y3)
    t.pendown()
    t.color(CENTER_COLOR)
    t.begin_fill()
    t.circle(CENTER_RADIUS)
    t.end_fill()
    return create_petal
