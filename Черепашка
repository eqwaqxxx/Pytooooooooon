# ПАРА 2 — ОБЛАКО
# =====================================================
CLOUD_COLOR = "white"
def create_cloud(cloud_x, cloud_y):
    t.color(CLOUD_COLOR)
    coords = [
        (80, 280, 40),
        (50, 260, 30),
        (110, 260, 30),
        (30, 250, 25),
        (130, 250, 25),
        (80, 270, 35)
    ]
    t.penup()
    t.goto(cloud_x, cloud_y)
    for circle_x, circle_y, radius in coords:
        t.penup()
        t.goto(circle_x + cloud_x, circle_y + cloud_y - radius)
        t.pendown()
        t.begin_fill()
        t.circle(radius)
        t.end_fill()

