def create_heart(x1,y1):
    t.penup()
    t.goto(x1, y1)
    t.pendown()
    t.color(HEART_COLOR)
    t.begin_fill()
    t.setheading(HEART_SETHEADING1)
    t.forward(HEART_FORWARD1)
    t.circle(HEART_RADIUS, 200)
    t.setheading(HEART_SETHEADING2)
    t.circle(HEART_RADIUS, 200)
    t.forward(HEART_FORWARD2)
    t.end_fill()

