HEART_COLOR = "red"
HEART_FORWARD1 = 62
HEART_SETHEADING1 = 140
HEART_FORWARD2 = 62
HEART_SETHEADING2 = 60
HEART_RADIUS = -35
def create_heart(x1,y1):
    t.penup()
    t.goto(x1, y1)
    t.pendown()
    t.color(HEART_COLOR)
    t.begin_fill()
    t.setheading(HEART_SETHEADING1)
    t.forward(HEART_FORWARD1)
    t.circle(HEART_RADIUS, 200)
    t.setheading(HEART_SETHEADING2)
    t.circle(HEART_RADIUS, 200)
    t.forward(HEART_FORWARD2)
    t.end_fill()

# НАДПИСЬ
MAIN_TEXT_COLOR = "purple"
SUB_TEXT1_COLOR = "deeppink"
SUB_TEXT2_COLOR = "blue"
MAIN_TEXT_SIZE = 36
SUB_TEXT1_SIZE = 20
SUB_TEXT2_SIZE = 14
def create_text(text, size, font_type,  x1,y1, color):
    t.penup()
    t.goto(x1, y1)
    t.pendown()
    t.color(color)
    t.write(text, align="center", font=(font_type, size, "bold"))

